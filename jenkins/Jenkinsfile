sh 'echo "TAG_NAME = ${TAG_NAME}"'
pipeline {
    agent any

    environment {
        DOCKER_REGISTRY = 'docker.io/egorich27'               // ваш Docker Hub логин
        BACKEND_IMAGE = "${DOCKER_REGISTRY}/kafka-control-backend:${BUILD_NUMBER}"
        FRONTEND_IMAGE = "${DOCKER_REGISTRY}/kafka-control-frontend:${BUILD_NUMBER}"
        GITHUB_TOKEN = credentials('github-token')            // GitHub токен (Secret text)
        GITHUB_REPO = 'Egorich88/kafka-system-control-4'      // ваш репозиторий
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh "docker login -u $DOCKER_USER -p $DOCKER_PASS"
                }
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh "docker build -t ${BACKEND_IMAGE} ."
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh "docker build -t ${FRONTEND_IMAGE} ."
                }
            }
        }

        stage('Push Images') {
            steps {
                sh "docker push ${BACKEND_IMAGE}"
                sh "docker push ${FRONTEND_IMAGE}"
            }
        }

        // stage('Deploy to Kubernetes') {
        //     steps {
        //         withKubeConfig([credentialsId: 'kubeconfig']) {
        //             sh "kubectl set image deployment/backend backend=${BACKEND_IMAGE} -n kafka-system"
        //             sh "kubectl set image deployment/frontend nginx=${FRONTEND_IMAGE} -n kafka-system"
        //         }
        //     }
        // }

        stage('Create GitHub Release') {
            when {
                // Запускаем только если переменная TAG_NAME определена (т.е. сборка по тегу)
                expression { env.TAG_NAME != null && env.TAG_NAME != '' }
                // Дополнительно можно проверить формат тега, например, v4.0.0
                // tag pattern: "v\\d+\\.\\d+\\.\\d+", comparator: "REGEXP"
            }
            steps {
                script {
                    def tagName = env.TAG_NAME
                    // Если нужно, можно сгенерировать описание релиза из файла CHANGELOG.md или просто сделать стандартное
                    def releaseBody = "Автоматический релиз от Jenkins.\n\nСборка #${BUILD_NUMBER}\n\n## Что нового\n- Исправлены ошибки сборки фронтенда\n- Настроен автоматический деплой\n- Добавлена поддержка тегов"
                    sh """
                        curl -X POST \
                          -H "Authorization: token ${GITHUB_TOKEN}" \
                          -H "Accept: application/vnd.github.v3+json" \
                          https://api.github.com/repos/${GITHUB_REPO}/releases \
                          -d '{
                            "tag_name": "${tagName}",
                            "name": "Release ${tagName}",
                            "body": "${releaseBody}",
                            "draft": false,
                            "prerelease": false
                          }'
                    """
                }
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed!'
        }
    }
}