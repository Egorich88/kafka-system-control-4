pipeline {
    agent any

    parameters {
        string(name: 'TAG_NAME', defaultValue: '', description: 'Git tag name (например, v4.0.1)')
    }

    environment {
        DOCKER_REGISTRY = 'docker.io/egorich27'
        BACKEND_IMAGE  = "${DOCKER_REGISTRY}/kafka-control-backend:${BUILD_NUMBER}"
        FRONTEND_IMAGE = "${DOCKER_REGISTRY}/kafka-control-frontend:${BUILD_NUMBER}"
        GITHUB_TOKEN   = credentials('github-token')
        GITHUB_REPO    = 'Egorich88/kafka-system-control-4'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'echo "TAG_NAME = ${TAG_NAME}"'
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'docker-hub-credentials',
                    usernameVariable: 'DOCKER_USER',
                    passwordVariable: 'DOCKER_PASS'
                )]) {
                    sh 'docker login -u $DOCKER_USER -p $DOCKER_PASS'
                }
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh "docker build -t ${BACKEND_IMAGE} ."
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh "docker build -t ${FRONTEND_IMAGE} ."
                }
            }
        }

        stage('Push Images') {
            steps {
                sh "docker push ${BACKEND_IMAGE}"
                sh "docker push ${FRONTEND_IMAGE}"
            }
        }

        stage('Create GitHub Release') {
            when {
                expression { params.TAG_NAME != null && params.TAG_NAME != '' }
            }
            steps {
                script {
                    def tagName = params.TAG_NAME
                    def releaseBody = "Автоматический релиз от Jenkins.\n\nСборка #${BUILD_NUMBER}\n\nТег: ${tagName}"
                    sh """
                        curl -X POST \
                          -H "Authorization: token ${GITHUB_TOKEN}" \
                          -H "Accept: application/vnd.github.v3+json" \
                          https://api.github.com/repos/${GITHUB_REPO}/releases \
                          -d '{
                            "tag_name": "${tagName}",
                            "name": "Release ${tagName}",
                            "body": "${releaseBody}",
                            "draft": false,
                            "prerelease": false
                          }'
                    """
                }
            }
        }
    }

    post {
        failure {
            echo 'Pipeline failed!'
        }
    }
}